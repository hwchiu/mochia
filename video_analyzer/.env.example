# ================================================
#  .env.example — 複製為 .env 並填入實際值
#  cp .env.example .env
# ================================================

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Azure OpenAI（GPT 摘要/分類 + Whisper 語音轉文字）──
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Worker 設定 ──
WORKER_CONCURRENCY=1        # 同時處理任務數（建議 1，避免 API 超頻）
WORKER_POLL_INTERVAL=5      # 輪詢間隔（秒）
WORKER_TASK_DELAY=2         # 任務間延遲（秒）
WORKER_MAX_RETRIES=3        # 最大重試次數
WORKER_RETRY_DELAY=30       # 重試前等待秒數
