#!/bin/bash
# ============================================================
#  Git pre-push hook
#  阻止直接 push 到 main branch，強制走 PR 流程
#  跳過（緊急）：git push --no-verify
# ============================================================

PROTECTED_BRANCH="main"
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT_BRANCH" = "$PROTECTED_BRANCH" ]; then
  echo ""
  echo "🚫 禁止直接 push 到 main branch！"
  echo ""
  echo "   請建立 feature branch 並開 PR："
  echo "   git checkout -b feat/your-feature-name"
  echo "   git push origin feat/your-feature-name"
  echo "   gh pr create --base main"
  echo ""
  echo "   緊急繞過：git push --no-verify"
  echo ""
  exit 1
fi

exit 0
