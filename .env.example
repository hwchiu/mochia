# ================================================
#  .env.example — 複製為 .env 並填入實際值
#  cp .env.example .env
# ================================================

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Azure OpenAI - GPT（摘要/分類/心智圖等）──
AZURE_OPENAI_API_KEY=your_gpt_resource_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-gpt-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure OpenAI - Whisper（語音轉文字）──
# 若 Whisper 部署在不同資源（不同區域），填入專屬的 Key 和 Endpoint
# 若與上方 GPT 同一個資源，這兩行可以留空（會自動沿用上方設定）
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper
AZURE_OPENAI_WHISPER_API_KEY=
AZURE_OPENAI_WHISPER_ENDPOINT=
AZURE_OPENAI_WHISPER_API_VERSION=  # 留空沿用上方版本，或指定如 2024-02-01

# ── Worker 設定 ──
WORKER_CONCURRENCY=1        # 同時處理任務數（建議 1，避免 API 超頻）
WORKER_POLL_INTERVAL=5      # 輪詢間隔（秒）
WORKER_TASK_DELAY=2         # 任務間延遲（秒）
WORKER_MAX_RETRIES=3        # 最大重試次數
WORKER_RETRY_DELAY=30       # 重試前等待秒數

# ── 影片來源目錄（最多 5 個，未設定的項目會忽略）──────────────────
# 每個目錄會掛載到容器內 /videos/source1 ~ /videos/source5
# 容器重啟後新來源才會生效（docker compose up -d）
VIDEO_DIR_1=/path/to/your/main/videos
VIDEO_DIR_2=                           # 可留空，例如: /Volumes/ExternalDrive/Videos
VIDEO_DIR_3=                           # 可留空
VIDEO_DIR_4=                           # 可留空
VIDEO_DIR_5=                           # 可留空

# ── Google Drive File Stream 相容模式 ──────────────────────────────
# 若影片存放在 Google Drive（桌面版「串流模式 / Stream files」），
# FFmpeg 直接 seek 不會觸發 GDrive 下載，導致分析失敗。
# 設為 true 後，分析開始前會先做 sequential pre-read，
# 強制觸發雲端下載後再交給 FFmpeg，進度顯示「從雲端下載影片中...」
# 若影片存放在本機硬碟，維持 false 即可，不會有任何影響。
ENABLE_FILE_WARMUP=false
